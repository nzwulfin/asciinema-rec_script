: # Record: asciinema-rec_script [-q] [-s slow|normal|fast] -t "Title" screencasts/template.asc
:clear
pause 2

say # Demo title

say Set the stage silently with `:` — not shown on screen
:export DEMO_VAR=hello

say Visible setup uses plain assignment
export ANOTHER_VAR=world

say Run commands normally — they type out and execute
echo "$DEMO_VAR $ANOTHER_VAR"

pause

say Inline `#` comments display as markdown alongside the command
ls /tmp # showing the temp directory

pause 2

say Multi-line commands use backslash continuation
echo "one" \
  && echo "two" \
  && echo "three"

pause 2

say Use `sleep N` for a visible countdown, `pause N` for silence
sleep 3

say The banner that follows is generated by the tool — suppress it with `-q`
